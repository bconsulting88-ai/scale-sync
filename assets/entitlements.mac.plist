<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Allow JIT compilation (required by Electron) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Allow unsigned executable memory (Electron v20+ requirement) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Required for native Node modules (.node files) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- USB serial port access for OHAUS Ranger -->
    <key>com.apple.security.device.usb</key>
    <true/>
    <!-- Network client access for Dutchie API -->
    <key>com.apple.security.network.client</key>
    <true/>
  </dict>
</plist>
